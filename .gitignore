# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# Environment files
.env
.env.*
!.env.example

# Node / frontend
web/node_modules/
web/dist/
web/.vite/

# Local database/data artifacts
*.dump
deployment/
data/raw/*
!data/raw/.gitkeep
!data/raw/anime-offline-database.jsonl.zst
data/processed/*
!data/processed/.gitkeep
!data/processed/user_profiles.jsonl.zst
!data/processed/mal_to_catalog.json

# Local generated media can become huge.
# Do not commit posters/thumbnails to GitHub.
media/posters/*
media/thumbnails/*
!media/posters/.gitkeep
!media/thumbnails/.gitkeep

# Benchmark artefacts
benchmark/cache/*
!benchmark/cache/llm.tar.zst
benchmark/results/*.json

# macOS
.DS_Store
